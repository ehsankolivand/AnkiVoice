# AnkiVoice configuration — copy to .env and fill in. Config is environment-only (Principle VIII).
# The bot reads these on startup. Never commit a real .env (it is gitignored).

# --- Required ---
# Bot auth token from @BotFather (SECRET).
ANKIVOICE_BOT_TOKEN=123456:ABCdefGhIjKlmNoPqrsTuvWxyz
# Operator-owned archive destination that receives a backup copy of every delivered package.
# A channel/group id (often negative, e.g. -1001234567890) or your own user id. The bot must be a
# member with permission to receive documents there.
ANKIVOICE_ARCHIVE_CHAT_ID=-1001234567890

# --- Optional (defaults shown) ---
# American-English voice id (see research.md for the 20 available). Default: af_heart.
ANKIVOICE_DEFAULT_VOICE=af_heart
# Kokoro language code: a = American English, b = British English. Default: a.
ANKIVOICE_LANG_CODE=a
# Per-job maximum number of cards (bounds synthesis time on one CPU core). Default: 200.
ANKIVOICE_MAX_CARDS=200
# Maximum accepted upload size in bytes (text decks are tiny; well under Telegram's ~20 MB cap).
# Default: 2000000 (2 MB).
ANKIVOICE_MAX_FILE_BYTES=2000000
# Root working directory for per-job dirs (cleaned after delivery). Default: ./work
ANKIVOICE_WORK_DIR=./work
# SQLite job-store path (the only datastore). Default: ./data/ankivoice.db
ANKIVOICE_DB_PATH=./data/ankivoice.db
# Optional: pin the offline model/voice cache location (sets HF_HOME). Default: HF's default cache.
# ANKIVOICE_MODEL_DIR=./models
# Optional: ffmpeg MP3 VBR quality (lower = higher quality/larger). Default: 4.
# ANKIVOICE_MP3_QUALITY=4

# --- Cycle 002 operational limits (defaults shown) ---
# Max retained terminal (cleaned/failed) job rows; older are pruned at startup so the datastore stays
# bounded. Default: 500.
# ANKIVOICE_JOB_HISTORY=500
# Seconds before an MP3 encode is aborted (a stuck encoder must not hang the single worker). Default: 120.
# ANKIVOICE_FFMPEG_TIMEOUT=120
# Bounded in-process delivery attempts (with backoff) before deferring to restart-resume. Default: 3.
# ANKIVOICE_DELIVERY_RETRIES=3
# Set to skip the fail-fast startup guard (espeak-ng + ffmpeg + configured voice/model). Tests/dev only.
# ANKIVOICE_SKIP_PREFLIGHT=
# Set to permit model/voice downloads at startup (e.g. for the one-time warm-up). Otherwise the process
# defaults HF_HUB_OFFLINE/TRANSFORMERS_OFFLINE to offline so synthesis never reaches the network.
# ANKIVOICE_ALLOW_DOWNLOADS=
